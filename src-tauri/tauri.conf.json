{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "SuperSearch",
  "version": "0.1.3",
  "identifier": "com.supersearch.desktop",
  "build": {
    "frontendDist": "../react-command-palette/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "cwd": "../react-command-palette", "script": "npm run dev" },
    "beforeBuildCommand": { "cwd": "../react-command-palette", "script": "npm run build" }
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "SuperSearch",
        "label": "main",
        "width": 720,
        "height": 480,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "© 2026 SuperSearch",
    "shortDescription": "AI-native productivity launcher",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      },
      "wix": {}
    }
  }
}
